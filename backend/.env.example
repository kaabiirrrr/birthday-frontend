# Backend environment variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/birthdayApp?retryWrites=true&w=majority

# Port (Railway sets this automatically)
PORT=3000

# Admin secret to view responses (choose any secret string)
ADMIN_SECRET=kabir_admin_secret_2024
